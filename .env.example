APP_NAME=GlobalNewsBackend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000
ASSET_URL=

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=
LOG_STDERR_FORMATTER=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=globalnewsbackend
